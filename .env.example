# Prism Docker Compose Configuration

# Images
BACKEND_IMAGE=ghcr.io/coachpo/prism-backend:latest
FRONTEND_IMAGE=ghcr.io/coachpo/prism-frontend:latest

# Published host ports (bound to loopback by default so traffic flows through your reverse proxy)
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8000
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_PORT=3000

# Optional compose network name for integrating with a reverse proxy stack
PRISM_NETWORK=prism

# Backend database location inside the backend container
DATABASE_URL=sqlite+aiosqlite:///./data/gateway.db
